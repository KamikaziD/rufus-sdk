# Confucius Workflow Engine - Environment Configuration

# ============================================================================
# STORAGE BACKEND
# ============================================================================

# Choose storage backend: 'redis' (development) or 'postgres' (production)
WORKFLOW_STORAGE=postgres

# PostgreSQL connection string (required if WORKFLOW_STORAGE=postgres)
DATABASE_URL=postgresql://confucius:password@localhost:5432/confucius

# ============================================================================
# CELERY
# ============================================================================

# Celery message broker (Redis)
CELERY_BROKER_URL=redis://localhost:6379/0

# Celery result backend (Redis)
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ============================================================================
# ENVIRONMENT
# ============================================================================

# Environment: 'development', 'staging', or 'production'
ENV=development

# Testing mode (set to 'true' for synchronous Celery execution in tests)
TESTING=false

# ============================================================================
# LOGGING
# ============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ============================================================================
# REGIONAL DATA SOVEREIGNTY
# ============================================================================

# Default data region for workflows
DEFAULT_DATA_REGION=us-east-1

# ============================================================================
# FEATURE FLAGS
# ============================================================================

# Enable saga mode by default for these workflow types (comma-separated)
SAGA_ENABLED_WORKFLOWS=Payment,BankTransfer,OrderProcessing,LoanApplication

# Maximum sub-workflow nesting depth
MAX_NESTING_DEPTH=3

# ============================================================================
# PERFORMANCE
# ============================================================================

# Worker concurrency (number of parallel tasks per worker)
CELERY_WORKER_CONCURRENCY=4

# Task timeout (seconds)
CELERY_TASK_TIMEOUT=3600

# ============================================================================
# SECURITY (if using mTLS)
# ============================================================================

# TLS/SSL configuration (optional)
# DATABASE_SSL_MODE=require
# DATABASE_SSL_CERT=/path/to/client-cert.pem
# DATABASE_SSL_KEY=/path/to/client-key.pem
# DATABASE_SSL_ROOT_CERT=/path/to/root-ca.pem
