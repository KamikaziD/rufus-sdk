// WIT interface for Rufus workflow step components.
//
// Components that implement this interface can be used as WASM steps in
// a Rufus workflow.  The host calls `execute` with the current workflow
// state (serialised as JSON) and the step name; the component returns
// either a JSON-encoded result dict or a structured error.
//
// Backward compatibility: Core WASM modules that use the legacy stdin/stdout
// contract are still supported by WasmRuntime._execute_wasi().  The new
// ComponentStepRuntime detects which format a binary uses and dispatches
// accordingly.

package rufus:step@0.1.0;

interface step-types {
  /// JSON-encoded workflow state dict passed to the component.
  type state-json = string;

  /// JSON-encoded result dict returned by the component.
  /// Keys are merged into workflow state using the configured merge strategy.
  type result-json = string;

  /// Structured error returned when the step fails.
  record step-error {
    /// Numeric error code (0 = generic, 1 = validation, 2 = timeout, 3 = business-logic).
    code: u32,
    /// Human-readable error message.
    message: string,
  }
}

/// The world exported by each workflow step component.
world step-component {
  use step-types.{state-json, result-json, step-error};

  /// Execute the workflow step.
  ///
  /// @param state     JSON-encoded current workflow state dict.
  /// @param step-name Name of the step being executed (for logging / routing).
  /// @returns         ok(result-json)  — dict to merge into state on success.
  ///                  err(step-error) — structured error on failure.
  export execute: func(
    state: state-json,
    step-name: string,
  ) -> result<result-json, step-error>;
}
