# FastAPI Configuration

# Database connection
DATABASE_URL=postgresql://rufus_user:rufus_password@localhost:5432/rufus_db

# Server configuration
PORT=8000
DEBUG=True

# Performance Optimizations (Phase 1)
# PostgreSQL connection pool settings (tuned for high performance)
POSTGRES_POOL_MIN_SIZE=10
POSTGRES_POOL_MAX_SIZE=50
POSTGRES_POOL_COMMAND_TIMEOUT=10
POSTGRES_POOL_MAX_QUERIES=50000
POSTGRES_POOL_MAX_INACTIVE_LIFETIME=300

# Performance features (enabled by default)
RUFUS_USE_UVLOOP=true  # 2-4x faster async I/O
RUFUS_USE_ORJSON=true  # 3-5x faster JSON serialization

# Workflow registry path (optional)
# WORKFLOW_REGISTRY_PATH=./workflow_registry.yaml
