# ============================================================================
# Rufus Edge Platform - Environment Configuration
# ============================================================================

# ----------------------------------------------------------------------------
# Performance Optimizations
# ----------------------------------------------------------------------------
RUFUS_USE_UVLOOP=true
RUFUS_USE_ORJSON=true


# ----------------------------------------------------------------------------
# Database Configuration
# ----------------------------------------------------------------------------
DATABASE_URL=postgresql://rufus:rufus_secret_2024@localhost:5433/rufus_cloud
WORKFLOW_STORAGE=postgres
SQLITE_DB_PATH=rufus_edge.db


# ----------------------------------------------------------------------------
# PostgreSQL Connection Pool Settings (Optimized for High-Load Testing)
# ----------------------------------------------------------------------------
POSTGRES_POOL_MIN_SIZE=50
POSTGRES_POOL_MAX_SIZE=500
POSTGRES_POOL_COMMAND_TIMEOUT=60
POSTGRES_POOL_MAX_QUERIES=500000
POSTGRES_POOL_MAX_INACTIVE_LIFETIME=600


# ----------------------------------------------------------------------------
# Server Configuration
# ----------------------------------------------------------------------------
HOST=0.0.0.0
PORT=8000
PUBLIC_URL=http://localhost:8000
LOG_LEVEL=INFO


# ----------------------------------------------------------------------------
# Security & Authentication
# ----------------------------------------------------------------------------
RUFUS_REGISTRATION_KEY=demo-registration-key-2024
# RUFUS_API_KEY=
RUFUS_ENCRYPTION_KEY=359b8828eaf484b52fe9c85fd0a7dd3e3a2f820a887ea654d7eddeb3423b4521
ENABLE_ENCRYPTION_AT_REST=true


# ----------------------------------------------------------------------------
# Rate Limiting
# ----------------------------------------------------------------------------
RATE_LIMIT_ENABLED=true
RATE_LIMIT_CACHE_TTL=60
RATE_LIMIT_CLEANUP_INTERVAL=300


# ----------------------------------------------------------------------------
# HTTP Client Retry Configuration (Device Simulator & Edge Agent)
# ----------------------------------------------------------------------------
MAX_RETRIES=3
INITIAL_BACKOFF=1.0
MAX_BACKOFF=10.0
BACKOFF_MULTIPLIER=2.0


# ----------------------------------------------------------------------------
# Workflow Engine Configuration
# ----------------------------------------------------------------------------
RUFUS_WORKFLOW_REGISTRY_PATH=config/workflow_registry.yaml
WORKFLOW_EXECUTION_BACKEND=sync


# ----------------------------------------------------------------------------
# Artifacts & Storage
# ----------------------------------------------------------------------------
ARTIFACTS_DIR=/app/artifacts


# ----------------------------------------------------------------------------
# Redis Configuration (optional)
# ----------------------------------------------------------------------------
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_URL=redis://localhost:6379/0


# ----------------------------------------------------------------------------
# Webhook Configuration
# ----------------------------------------------------------------------------
# WEBHOOK_RETRY_MAX_CONCURRENT=10
# WEBHOOK_RETRY_SCAN_INTERVAL=60


# ----------------------------------------------------------------------------
# Load Testing Configuration
# ----------------------------------------------------------------------------
CLOUD_URL=http://localhost:8000
LOAD_TEST_DEVICES=500
LOAD_TEST_DURATION=600
LOAD_TEST_API_KEY_PREFIX=load_test_api_key
LOAD_TEST_DEVICE_TYPE=pos_terminal
LOAD_TEST_MERCHANT_ID=merchant_load_test


# ----------------------------------------------------------------------------
# Testing & Development
# ----------------------------------------------------------------------------
TESTING=false
PYTEST_TIMEOUT=300
TEST_VERBOSE=false
