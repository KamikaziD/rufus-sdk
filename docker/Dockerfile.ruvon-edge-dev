FROM python:3.11-slim

LABEL maintainer="Ruvon Team <team@ruvon.dev>"
LABEL description="Ruvon Edge — Device Emulator (dev image)"
LABEL version="0.1.0"

WORKDIR /app

RUN apt-get update && apt-get install -y gcc && rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir \
    'ruvon-edge[edge]==0.1.0' \
    'httpx>=0.24' \
    'aiosqlite>=0.19'

COPY examples/edge_deployment/edge_device_sim.py /app/edge_device_sim.py

# Pre-built WASM binaries (no toolchain required at runtime)
COPY src/ruvon_edge/sidecar/wasm/apply_config.wasm /app/ruvon_edge/sidecar/wasm/apply_config.wasm
COPY src/ruvon_edge/sidecar/wasm/apply_config.sha256 /app/ruvon_edge/sidecar/wasm/apply_config.sha256
COPY examples/edge_deployment/fraud_scorer.wasm /app/fraud_scorer.wasm

CMD ["python", "edge_device_sim.py"]
