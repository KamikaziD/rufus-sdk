{
  "realm": "rufus",
  "enabled": true,
  "displayName": "Rufus Edge Platform",
  "sslRequired": "none",
  "accessTokenLifespan": 300,
  "ssoSessionMaxLifespan": 36000,
  "clients": [
    {
      "clientId": "rufus-dashboard",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "redirectUris": [
        "http://localhost:3000/*",
        "http://127.0.0.1:3000/*"
      ],
      "webOrigins": [
        "http://localhost:3000",
        "http://127.0.0.1:3000"
      ],
      "protocolMappers": [
        {
          "name": "realm-roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "claim.name": "realm_access.roles",
            "jsonType.label": "String",
            "access.token.claim": "true",
            "id.token.claim": "true",
            "multivalued": "true"
          }
        },
        {
          "name": "org-id",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "org_id",
            "claim.name": "org_id",
            "jsonType.label": "String",
            "access.token.claim": "true",
            "id.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "rufus-server",
      "enabled": true,
      "bearerOnly": true
    }
  ],
  "roles": {
    "realm": [
      {"name": "SUPER_ADMIN",        "description": "Full system access"},
      {"name": "FLEET_MANAGER",      "description": "Device fleet management"},
      {"name": "WORKFLOW_OPERATOR",  "description": "Workflow creation and HITL approvals"},
      {"name": "AUDITOR",            "description": "Read-only audit and compliance access"},
      {"name": "READ_ONLY",          "description": "Read-only dashboard access"}
    ]
  },
  "users": [
    {
      "username": "admin",
      "enabled": true,
      "email": "admin@rufus.dev",
      "firstName": "Super",
      "lastName": "Admin",
      "credentials": [{"type": "password", "value": "rufus-dev", "temporary": false}],
      "realmRoles": ["SUPER_ADMIN"]
    },
    {
      "username": "fleet",
      "enabled": true,
      "email": "fleet@rufus.dev",
      "firstName": "Fleet",
      "lastName": "Manager",
      "credentials": [{"type": "password", "value": "rufus-dev", "temporary": false}],
      "realmRoles": ["FLEET_MANAGER"]
    },
    {
      "username": "operator",
      "enabled": true,
      "email": "operator@rufus.dev",
      "firstName": "Workflow",
      "lastName": "Operator",
      "credentials": [{"type": "password", "value": "rufus-dev", "temporary": false}],
      "realmRoles": ["WORKFLOW_OPERATOR"]
    },
    {
      "username": "auditor",
      "enabled": true,
      "email": "auditor@rufus.dev",
      "firstName": "Compliance",
      "lastName": "Auditor",
      "credentials": [{"type": "password", "value": "rufus-dev", "temporary": false}],
      "realmRoles": ["AUDITOR"]
    },
    {
      "username": "readonly",
      "enabled": true,
      "email": "readonly@rufus.dev",
      "firstName": "Read",
      "lastName": "Only",
      "credentials": [{"type": "password", "value": "rufus-dev", "temporary": false}],
      "realmRoles": ["READ_ONLY"]
    }
  ]
}
