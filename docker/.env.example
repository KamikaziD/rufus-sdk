# Rufus Docker Environment Configuration
# Copy this file to .env and customize for your environment

# ============================================================================
# CRITICAL: Encryption Key (REQUIRED for production)
# ============================================================================
# This key is used to encrypt workflow state in the database.
# - MUST be set to a persistent value in production
# - MUST be the same across all containers (server + workers)
# - If changed, existing encrypted workflows cannot be decrypted
#
# Generate a new key with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#
# Example:
# RUFUS_ENCRYPTION_KEY=your-generated-key-here
RUFUS_ENCRYPTION_KEY=

# ============================================================================
# Database Configuration
# ============================================================================
POSTGRES_USER=rufus
POSTGRES_PASSWORD=rufus_secret_2024
POSTGRES_DB=rufus_production

# ============================================================================
# Redis Configuration
# ============================================================================
# Redis is used for Celery broker/backend and pub/sub events
# REDIS_URL is automatically set in docker-compose

# ============================================================================
# Worker Configuration
# ============================================================================
WORKER_CONCURRENCY=4
WORKER_POOL=prefork
WORKER_LOG_LEVEL=info
WORKER_REGION=us-east-1
WORKER_ZONE=zone-a

# ============================================================================
# Server Configuration
# ============================================================================
RUFUS_REGISTRATION_KEY=demo-registration-key-2024
