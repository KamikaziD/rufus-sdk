# Rufus Docker Environment Variables
# Copy this file to .env and customize as needed
# Usage: docker compose --env-file .env up -d

# ─────────────────────────────────────────────────────────────────────────
# PostgreSQL Database Configuration
# ─────────────────────────────────────────────────────────────────────────

# Database credentials
POSTGRES_USER=rufus
POSTGRES_PASSWORD=rufus_secret_2024
POSTGRES_DB=rufus_cloud

# External port mapping (host:container)
POSTGRES_PORT=5433

# PostgreSQL Performance Tuning
POSTGRES_MAX_CONNECTIONS=1000
POSTGRES_SHARED_BUFFERS=512MB
POSTGRES_MAX_WAL_SIZE=2GB

# ─────────────────────────────────────────────────────────────────────────
# Rufus Server Configuration
# ─────────────────────────────────────────────────────────────────────────

# Server port (external)
RUFUS_SERVER_PORT=8000

# Workflow storage backend
WORKFLOW_STORAGE=postgres

# Registration key for edge device enrollment
RUFUS_REGISTRATION_KEY=demo-registration-key-2024

# ─────────────────────────────────────────────────────────────────────────
# PostgreSQL Connection Pool
# ─────────────────────────────────────────────────────────────────────────

# Pool sizing (adjust based on load)
# - Low concurrency (<10 workflows): min=10, max=50
# - Medium concurrency (10-100 workflows): min=50, max=200
# - High concurrency (>100 workflows): min=100, max=500
POSTGRES_POOL_MIN_SIZE=50
POSTGRES_POOL_MAX_SIZE=500
POSTGRES_POOL_COMMAND_TIMEOUT=60
POSTGRES_POOL_MAX_QUERIES=500000
POSTGRES_POOL_MAX_INACTIVE_LIFETIME=600

# ─────────────────────────────────────────────────────────────────────────
# Application Configuration
# ─────────────────────────────────────────────────────────────────────────

# Artifacts storage directory
ARTIFACTS_DIR=/app/artifacts

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# ─────────────────────────────────────────────────────────────────────────
# Notes
# ─────────────────────────────────────────────────────────────────────────

# 1. Environment variables are loaded in this order:
#    - Defaults in docker-compose.yml (${VAR:-default})
#    - .env file (if present)
#    - System environment variables
#    - docker compose --env-file override
#
# 2. For production deployments:
#    - Change POSTGRES_PASSWORD to a strong password
#    - Change RUFUS_REGISTRATION_KEY to a secure random string
#    - Adjust connection pool sizing based on expected load
#
# 3. For development:
#    - Use defaults (no .env file needed)
#    - Or copy this file to .env and customize
#
# 4. To use a different database:
#    - Set POSTGRES_USER, POSTGRES_PASSWORD, POSTGRES_DB
#    - Update DATABASE_URL accordingly in docker-compose.yml
