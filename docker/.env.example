# Rufus Docker Environment Configuration
# Copy this file to .env and customize for your environment

# ============================================================================
# CRITICAL: Encryption Key (REQUIRED for production)
# ============================================================================
# This key is used to encrypt workflow state in the database.
# - MUST be set to a persistent value in production
# - MUST be the same across all containers (server + workers)
# - If changed, existing encrypted workflows cannot be decrypted
#
# Generate a new key with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#
# Example:
# RUVON_ENCRYPTION_KEY=your-generated-key-here
RUVON_ENCRYPTION_KEY=

# ============================================================================
# Database Configuration
# ============================================================================
POSTGRES_USER=ruvon
POSTGRES_PASSWORD=ruvon_secret_2024
POSTGRES_DB=ruvon_production

# ============================================================================
# Redis Configuration
# ============================================================================
# Redis is used for Celery broker/backend and pub/sub events
# REDIS_URL is automatically set in docker-compose

# ============================================================================
# Worker Configuration
# ============================================================================
WORKER_CONCURRENCY=4
WORKER_POOL=prefork
WORKER_LOG_LEVEL=info
WORKER_REGION=us-east-1
WORKER_ZONE=zone-a

# ============================================================================
# Server Configuration
# ============================================================================
RUVON_REGISTRATION_KEY=demo-registration-key-2024

# ============================================================================
# Custom API Router Extensions (optional)
# ============================================================================
# Mount user-defined FastAPI routers into the Rufus server.
# Comma-separated list of dotted Python paths to APIRouter objects.
# Example: RUVON_CUSTOM_ROUTERS=my_app.routes.router,my_app.webhooks.router
# RUVON_CUSTOM_ROUTERS=

# ============================================================================
# Authentication / RBAC (optional — disabled by default)
# ============================================================================
# RUVON_AUTH_PROVIDER=disabled   # disabled | keycloak | jwt | api_key | custom

# Keycloak (when RUVON_AUTH_PROVIDER=keycloak):
# Requires: pip install 'ruvon-sdk[auth]'
# KEYCLOAK_SERVER_URL=https://keycloak.example.com
# KEYCLOAK_REALM=my-realm
# KEYCLOAK_CLIENT_ID=ruvon-api
# KEYCLOAK_AUDIENCE=ruvon-api    # optional, defaults to KEYCLOAK_CLIENT_ID

# Generic JWT (when RUVON_AUTH_PROVIDER=jwt):
# Requires: pip install 'ruvon-sdk[auth]'
# JWT_ALGORITHM=HS256            # HS256 or RS256
# JWT_SECRET_KEY=my-secret       # HS256 only
# JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----...  # RS256 only
# JWT_ISSUER=https://my-auth-server  # optional iss claim check

# API Key (when RUVON_AUTH_PROVIDER=api_key):
# RUVON_API_KEYS=key1:user1:role1,role2;key2:user2:admin

# Custom provider (when RUVON_AUTH_PROVIDER=custom):
# RUVON_CUSTOM_AUTH_PROVIDER=my_app.auth.MyProvider

# ============================================================================
# Dashboard (Next.js) Configuration
# ============================================================================
# NEXTAUTH_URL=http://localhost:3000
# NEXTAUTH_SECRET=change-me-to-32-random-bytes

# ============================================================================
# Keycloak OIDC (for dashboard auth + API token validation)
# ============================================================================
# Keycloak admin
# KEYCLOAK_ADMIN_PASSWORD=admin_secret
# KEYCLOAK_PORT=8080

# next-auth Keycloak provider (dashboard)
# KEYCLOAK_CLIENT_ID=ruvon-dashboard
# KEYCLOAK_ISSUER=http://localhost:8080/realms/ruvon

# Rufus API server Keycloak validation
# RUVON_AUTH_PROVIDER=keycloak
# KEYCLOAK_SERVER_URL=http://keycloak:8080
# KEYCLOAK_REALM=ruvon
# KEYCLOAK_CLIENT_ID=ruvon-server
# KEYCLOAK_AUDIENCE=ruvon-server

# ============================================================================
# CORS (allowed dashboard origins for Rufus API server)
# ============================================================================
# RUVON_CORS_ORIGINS=http://localhost:3000,https://dashboard.example.com
