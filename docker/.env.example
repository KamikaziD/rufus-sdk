# Docker Environment Configuration for Rufus Celery Workers
# Copy this file to .env and customize

# PostgreSQL Configuration
POSTGRES_PASSWORD=rufus_secret_2024
POSTGRES_DB=rufus_production
POSTGRES_USER=rufus

# Celery Worker Configuration
WORKER_CONCURRENCY=4
WORKER_POOL=prefork  # Options: prefork, gevent, eventlet
WORKER_LOG_LEVEL=info  # Options: debug, info, warning, error
WORKER_REGION=us-east-1
WORKER_ZONE=zone-a

# Redis Configuration
REDIS_MAX_MEMORY=2gb

# Optional: Worker Capabilities (JSON)
WORKER_CAPABILITIES={"gpu": false, "ml": false, "high_memory": false}
