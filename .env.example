# ============================================================================
# Rufus Edge Platform - Environment Configuration
# ============================================================================
# Copy this file to .env and configure for your environment
# ============================================================================

# ----------------------------------------------------------------------------
# Performance Optimizations
# ----------------------------------------------------------------------------
# Enable uvloop for faster async I/O (2-4x improvement)
RUFUS_USE_UVLOOP=true

# Enable orjson for faster JSON serialization (3-5x improvement)
RUFUS_USE_ORJSON=true


# ----------------------------------------------------------------------------
# Database Configuration
# ----------------------------------------------------------------------------
# Primary database URL (PostgreSQL recommended for production)
DATABASE_URL=postgresql://rufus:rufus_secret_2024@localhost:5433/rufus_cloud

# Workflow storage backend: sqlite, postgres, redis
WORKFLOW_STORAGE=postgres

# SQLite database path (used when WORKFLOW_STORAGE=sqlite)
SQLITE_DB_PATH=rufus_edge.db


# ----------------------------------------------------------------------------
# PostgreSQL Connection Pool Settings
# ----------------------------------------------------------------------------
# Pool size settings (adjust based on expected concurrency)
# For development: MIN=10, MAX=50
# For production (100-500 devices): MIN=50, MAX=500
# For high-scale (1000+ devices): MIN=100, MAX=1000
POSTGRES_POOL_MIN_SIZE=50
POSTGRES_POOL_MAX_SIZE=500

# Command timeout (seconds) - how long to wait for query completion
POSTGRES_POOL_COMMAND_TIMEOUT=60

# Maximum queries per connection before recycling
POSTGRES_POOL_MAX_QUERIES=500000

# Maximum connection idle time (seconds) before closing
POSTGRES_POOL_MAX_INACTIVE_LIFETIME=600


# ----------------------------------------------------------------------------
# Server Configuration
# ----------------------------------------------------------------------------
# Server host and port
HOST=0.0.0.0
PORT=8000

# Public URL for generating links (webhooks, notifications, etc.)
PUBLIC_URL=http://localhost:8000

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO


# ----------------------------------------------------------------------------
# Security & Authentication
# ----------------------------------------------------------------------------
# Registration key for device enrollment
RUFUS_REGISTRATION_KEY=demo-registration-key-2024

# API key for authenticated endpoints (optional)
RUFUS_API_KEY=

# Encryption key for data at rest (32-byte hex string)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
RUFUS_ENCRYPTION_KEY=

# Enable encryption at rest for sensitive data
ENABLE_ENCRYPTION_AT_REST=false


# ----------------------------------------------------------------------------
# Rate Limiting
# ----------------------------------------------------------------------------
# Enable global rate limiting to prevent API abuse
RATE_LIMIT_ENABLED=true

# Cache TTL for rate limit rules (seconds)
RATE_LIMIT_CACHE_TTL=60

# Cleanup interval for expired rate limit entries (seconds)
RATE_LIMIT_CLEANUP_INTERVAL=300


# ----------------------------------------------------------------------------
# HTTP Client Retry Configuration (Device Simulator & Edge Agent)
# ----------------------------------------------------------------------------
# Maximum number of retry attempts for failed HTTP requests
MAX_RETRIES=3

# Initial backoff delay (seconds)
INITIAL_BACKOFF=1.0

# Maximum backoff delay (seconds)
MAX_BACKOFF=10.0

# Backoff multiplier (exponential: 1s, 2s, 4s, 8s...)
BACKOFF_MULTIPLIER=2.0


# ----------------------------------------------------------------------------
# Workflow Engine Configuration
# ----------------------------------------------------------------------------
# Workflow registry path (YAML file listing all workflows)
RUFUS_WORKFLOW_REGISTRY_PATH=config/workflow_registry.yaml

# Workflow execution backend: sync, thread_pool, celery
WORKFLOW_EXECUTION_BACKEND=sync


# ----------------------------------------------------------------------------
# Artifacts & Storage
# ----------------------------------------------------------------------------
# Directory for storing ML models, firmware updates, etc.
ARTIFACTS_DIR=/app/artifacts


# ----------------------------------------------------------------------------
# Redis Configuration (optional - for Celery or caching)
# ----------------------------------------------------------------------------
# Redis host (used for distributed execution and caching)
REDIS_HOST=localhost

# Redis port
REDIS_PORT=6379

# Redis URL (auto-constructed if not specified)
REDIS_URL=redis://localhost:6379/0


# ----------------------------------------------------------------------------
# Webhook Configuration
# ----------------------------------------------------------------------------
# Maximum concurrent webhook deliveries
WEBHOOK_RETRY_MAX_CONCURRENT=10

# Webhook retry scan interval (seconds)
WEBHOOK_RETRY_SCAN_INTERVAL=60


# ----------------------------------------------------------------------------
# Load Testing Configuration
# ----------------------------------------------------------------------------
# Cloud URL for device simulator (defaults to http://localhost:8000)
CLOUD_URL=http://localhost:8000

# Number of devices to simulate in load tests
LOAD_TEST_DEVICES=100

# Load test duration (seconds)
LOAD_TEST_DURATION=600

# Device API key prefix for load testing
LOAD_TEST_API_KEY_PREFIX=load_test_api_key

# Device type for simulated devices
LOAD_TEST_DEVICE_TYPE=pos_terminal

# Merchant ID for load test devices
LOAD_TEST_MERCHANT_ID=merchant_load_test


# ----------------------------------------------------------------------------
# Testing & Development
# ----------------------------------------------------------------------------
# Enable testing mode (in-memory database, etc.)
TESTING=false

# pytest configuration
PYTEST_TIMEOUT=300

# Enable verbose logging during tests
TEST_VERBOSE=false


# ----------------------------------------------------------------------------
# Docker Compose — PostgreSQL (direct vars used by compose services)
# ----------------------------------------------------------------------------
POSTGRES_DB=rufus_production
POSTGRES_USER=rufus
POSTGRES_PASSWORD=rufus_secret_2024


# ----------------------------------------------------------------------------
# Celery Workers
# ----------------------------------------------------------------------------
WORKER_CONCURRENCY=4
WORKER_POOL=prefork
WORKER_LOG_LEVEL=info
WORKER_REGION=us-east-1
WORKER_ZONE=zone-a


# ----------------------------------------------------------------------------
# NATS JetStream
# ----------------------------------------------------------------------------
RUFUS_NATS_URL=nats://localhost:4222

# Protobuf serialization backend
RUFUS_PROTO_BACKEND=google


# ----------------------------------------------------------------------------
# Keycloak Identity Provider
# ----------------------------------------------------------------------------
KEYCLOAK_ADMIN_PASSWORD=admin_secret
KEYCLOAK_CLIENT_ID=rufus-dashboard
# Get from Keycloak admin → Clients → rufus-dashboard → Credentials tab
KEYCLOAK_SECRET=
KEYCLOAK_ISSUER=http://localhost:8080/realms/rufus


# ----------------------------------------------------------------------------
# Dashboard (Next.js / NextAuth)
# ----------------------------------------------------------------------------
NEXTAUTH_URL=http://localhost:3000
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
NEXTAUTH_SECRET=dev-secret-rufus-dashboard-2026-x
NEXT_PUBLIC_RUFUS_API_URL=http://localhost:8000
NEXT_PUBLIC_NATS_WS_URL=ws://localhost:8081


# ============================================================================
# Docker Compose Override
# ============================================================================
# When running via docker-compose, these values may be overridden by
# docker-compose.yml environment section. The values above are used when
# running services directly (e.g., uvicorn, pytest).
# ============================================================================
